        ],
        "inputAnchors": [],
        "inputs": {
          "template": "You are Agent 1 of VitalAI - a cardiovascular risk analysis assistant.\n\nRead the input carefully:\n{input}\n\nDECISION — choose ONE path only:\n\nPATH A — If input contains patient medical data with ML model results (contains numbers like age, BP, cholesterol, probability scores):\nProvide this structured output:\nRISK CLASSIFICATION: [HIGH / MEDIUM / LOW]\nRISK SCORE: [X/10]\nML PROBABILITY SCORE: [from actual model output]\nPATIENT ID NOTE: Consult a physician before taking any action\nKEY CONCERN: [one line summary]\nDETAILED ANALYSIS: 3-4 sentences on concerning values.\nSending to Agent 2 for recommendations...\n\nPATH B — PATH B — If input is a follow up question OR a short personal statement OR additional context about the patient (contains words like what, how, why, is, can, should, does, explain, tell me, is this, am I, dangerous, worried, eat, exercise, doctor, but, also, and, i am, i have, i feel, vegetarian, vegan, diabetic, smoker, or any sentence that is NOT a list of medical numbers):\nAnswer ONLY the question in 2-3 simple conversational sentences.\nDo NOT generate a full report.\nDo NOT say \"Sending to Agent 2\".\nJust answer helpfully and stop completely.",
          "promptValues": ""
        },
        "outputAnchors": [
          {
            "id": "promptTemplate_0-output-promptTemplate-PromptTemplate|BaseStringPromptTemplate|BasePromptTemplate|Runnable",
            "name": "promptTemplate",
            "label": "PromptTemplate",
            "description": "Schema to represent a basic prompt for an LLM",
            "type": "PromptTemplate | BaseStringPromptTemplate | BasePromptTemplate | Runnable"
          }
        ],
